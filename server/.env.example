PORT=5001
# Nếu chạy trên mạng LAN, thêm IP máy vào CLIENT_URL để cho phép origin
# Ví dụ: CLIENT_URL=http://192.168.1.10:3001,http://192.168.1.10:3002
CLIENT_URL=http://localhost:3001,http://localhost:3002

# PostgreSQL connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=library_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this
JWT_EXPIRE=7d

# Library settings
MAX_BORROW_BOOKS=5
DEFAULT_BORROW_DAYS=14
FINE_PER_DAY=2000

# ─── Cấu hình mạng LAN ────────────────────────────────────────────────────────
# Danh sách prefix IP của mạng nội bộ, ngăn cách bằng dấu phẩy
# Mặc định (không cần set): 192.168.x.x, 10.x.x.x, 172.16-31.x.x, 127.x
# Ví dụ nếu mạng trường dùng dải 172.20.x.x và 10.10.x.x:
#   LAN_SUBNETS=172.20.,10.10.,127.
LAN_SUBNETS=192.168.,10.,172.16.,172.17.,172.18.,172.19.,172.20.,172.21.,172.22.,172.23.,172.24.,172.25.,172.26.,172.27.,172.28.,172.29.,172.30.,172.31.,127.,::1,::ffff:127.
